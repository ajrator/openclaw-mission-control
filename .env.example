# Mission Control environment variables
# Copy this file to .env.local and fill in at least AUTH_SECRET.

# Required: NextAuth session signing. Generate with: npx auth secret
AUTH_SECRET=

# Optional: Origin Mission Control is served from (for gateway Control UI). Default: http://localhost:3000
# MISSION_CONTROL_ORIGIN=http://localhost:3000

# Optional: Notion OAuth (Integrations → Notion). Or use NOTION_API_KEY + NOTION_TASKS_DATABASE_ID.
# NOTION_OAUTH_CLIENT_ID=
# NOTION_OAUTH_CLIENT_SECRET=
# NOTION_OAUTH_REDIRECT_URI=

# Optional: Notion internal integration (alternative to OAuth)
# NOTION_API_KEY=
# NOTION_TASKS_DATABASE_ID=

# Optional: OpenAI (Codex) OAuth for chat. See Integrations in the app.
# OPENAI_OAUTH_CLIENT_ID=
# OPENAI_OAUTH_CLIENT_SECRET=
# OPENAI_OAUTH_REDIRECT_URI=

# Optional: Google sign-in
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
